IMAP_SERVER=imap.example.com
IMAP_PORT=993
EMAIL_ACCOUNT=info@example.com
EMAIL_PASSWORD=supersecretpassword

# S/MIME Certificate (P12/PFX format)
P12_CERTIFICATE_PATH=./certificate.p12
PFX_PASSWORD=

# Output configuration
SAVE_DIRECTORY=./output
SUBJECT_KEYWORD="Auftrag"

# Email post-processing action after successful decryption
# Options:
#   - "mark_seen" (default): Mark email as read
#   - "delete": Delete the email
#   - "move:FolderName": Move to specified IMAP folder (e.g., "move:Archive")
EMAIL_ACTION=mark_seen

# Action for older duplicate emails (same subject, older timestamp)
# When multiple emails have the same subject, only the latest is processed
# Options: Same as EMAIL_ACTION
# Note: Use "ignore" or leave empty to skip handling duplicates
DUPLICATE_ACTION=mark_seen

# PDF renaming pattern (optional)
# Available variables:
#   {last_name}                     - Last name from PDF
#   {first_name}                    - First name from PDF
#   {birth_date}                    - Birth date (DD.MM.YYYY format)
#   {barcode_number}                - Barcode number
#   {samplecollectiondate}          - Sample collection date (DD.MM.YYYY)
#   {receiptdate}                       - Receipt date (DD.MM.YYYY HH:MM)
#   {finalreport}                   - Final report date (DD.MM.YYYY)
#   {samplecollectiondate_yyyymmdd} - Sample date in YYYYMMDD format
#   {receiptdate_yyyymmdd}              - Receipt date in YYYYMMDD format
#   {finalreport_yyyymmdd}          - Final report date in YYYYMMDD format
#
# Examples:
#   "{last_name}_{first_name}_{barcode_number}.pdf"
#   "{finalreport_yyyymmdd}_{last_name}_{barcode_number}.pdf"
#   "Lab_{barcode_number}_{samplecollectiondate_yyyymmdd}.pdf"
#
# Leave empty to disable renaming
RENAME_PATTERN="{last_name}_{first_name}_{birth_date}_{barcode_number}.pdf"