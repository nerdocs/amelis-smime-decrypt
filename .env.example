IMAP_SERVER=imap.example.com
IMAP_PORT=993
EMAIL_ACCOUNT=info@example.com
EMAIL_PASSWORD=supersecretpassword

# S/MIME Certificate (P12/PFX format)
P12_CERTIFICATE_PATH=./certificate.p12
PFX_PASSWORD=

# Output configuration
SAVE_DIRECTORY=./output
SUBJECT_KEYWORD="Auftrag"

# Email post-processing action after successful decryption
# Options:
#   - "mark_seen" (default): Mark email as read
#   - "delete": Delete the email
#   - "move:FolderName": Move to specified IMAP folder (e.g., "move:Archive")
EMAIL_ACTION=mark_seen